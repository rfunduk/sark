# Sark Config
# "${VAR}" will be interpolated from env vars.
# Paths are absolute or relative to this config file.

listen: 0.0.0.0:8080
data_dir: /storage/data
log_level: info
hot_reload: true

# Optional; only required if any plugin defines workers.
anthropic_api_key: "${ANTHROPIC_API_KEY}"

# Bearer tokens. Each entry:
#   { name: <label>, plugins: [<plugin1>, <plugin2>, ...] | ["*"], token: <secret> }
tokens:
  - { name: default, plugins: ["*"], token: "${SARK_TOKEN}" }

# Plugin map: name → directory. The name is the routing key everywhere
# (URL path `/<name>/mcp`, DB filename, token scopes).
plugins:
  myplugin: /storage/plugins/myplugin
